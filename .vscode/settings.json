{
    // set claude code to use plan mode by default
    "claudeCode.initialPermissionMode": "plan",
    // format on save
    "editor.formatOnSave": true,
    // disable auto-detection of indentation to ensure consistent formatting
    "editor.detectIndentation": false,
    // indent with tabs and set tab size to 8
    "[typescript]": {
        "editor.insertSpaces": false,
        "editor.tabSize": 8
    },
    "[typescriptreact]": {
        "editor.insertSpaces": false,
        "editor.tabSize": 8
    },
    "[JSON]": {
        "editor.insertSpaces": false,
        "editor.tabSize": 8
    },
}