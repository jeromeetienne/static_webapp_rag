{
    "name": "static-webapp-rag",
    "private": true,
    "version": "0.0.1",
    "type": "module",
    "scripts": {
        "dev": "vite",
        "build": "tsc --noEmit && vite build",
        "preview": "vite preview",
        "chunk:naive": "tsx scripts/chunk-docs-naive.ts",
        "build-index": "tsx scripts/build-index.ts",
        "fetch-wiki": "tsx scripts/fetch-wikipedia.ts",
        "predeploy": "npm run build-index && vite build --base=/static_webapp_rag/",
        "deploy": "gh-pages -d dist"
    },
    "devDependencies": {
        "@types/mdast": "^4.0.4",
        "@types/node": "^22.10.0",
        "commander": "^14.0.3",
        "gh-pages": "^6.3.0",
        "mdast-util-to-string": "^4.0.0",
        "remark-gfm": "^4.0.1",
        "remark-parse": "^11.0.0",
        "tsx": "^4.19.0",
        "typescript": "^5.6.0",
        "unified": "^11.0.5",
        "vite": "^6.0.0"
    },
    "dependencies": {
        "@huggingface/transformers": "^4.2.0",
        "@mlc-ai/web-llm": "^0.2.83"
    }
}
